{
  "manifest_version": 3,
  "name": "PokeClicker Pro",
  "version": "1.2",
  "permissions": ["scripting"],
  "host_permissions": ["https://pokeapi.co/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ]
}