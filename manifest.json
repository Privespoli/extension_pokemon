{
  "manifest_version": 3,
  "name": "PokeClicker Aleatório",
  "version": "1.1",
  "description": "Invoca um Pokémon aleatório ao clicar.",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ],
  "host_permissions": [
    "https://pokeapi.co/*"
  ]
}